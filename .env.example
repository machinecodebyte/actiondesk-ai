# App
NODE_ENV=development
APP_NAME=ActionDesk AI
APP_VERSION=0.1.0
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=5000

# Frontend
WEB_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=ActionDesk AI
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:4000

# API Gateway
API_GATEWAY_URL=http://localhost:4000
API_GATEWAY_PORT=4000
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# Internal Service URLs
AUTH_SERVICE_URL=http://localhost:4010
INTEGRATION_SERVICE_URL=http://localhost:4011
MAIL_SERVICE_URL=http://localhost:4012
CALENDAR_SERVICE_URL=http://localhost:4013
COMMAND_SERVICE_URL=http://localhost:4014
AI_SERVICE_URL=http://localhost:4015
AGENT_SERVICE_URL=http://localhost:4016
SEARCH_SERVICE_URL=http://localhost:4017
WEBHOOK_SERVICE_URL=http://localhost:4018
WORKER_SERVICE_URL=http://localhost:4019
REALTIME_SERVICE_URL=http://localhost:4020

# Database
DATABASE_URL=postgresql://<user>:<password>@localhost:5432/actiondesk_ai
DATABASE_SSL=false
POSTGRES_USER=actiondesk
POSTGRES_PASSWORD=
POSTGRES_DB=actiondesk_ai
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=actiondesk
REDIS_PORT=6379

# Auth placeholder
AUTH_SECRET=
AUTH_COOKIE_NAME=actiondesk_session

# Corsair placeholder
CORSAIR_API_BASE_URL=
CORSAIR_CLIENT_ID=
CORSAIR_CLIENT_SECRET=

# AI placeholder
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
SERVICE_NAMESPACE=actiondesk-ai

# Security
TRUST_PROXY=false
SECURE_COOKIES=false
ENCRYPTION_KEY=
