# App
NODE_ENV=development
APP_NAME=ActionDesk AI
APP_VERSION=0.1.0
LOG_LEVEL=info
REQUEST_TIMEOUT_MS=5000

# Frontend
WEB_URL=http://localhost:3050
NEXT_PUBLIC_WEB_URL=http://localhost:3050
NEXT_PUBLIC_APP_NAME=ActionDesk AI
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:4050

# API Gateway
API_GATEWAY_URL=http://localhost:4050
API_GATEWAY_PORT=4050
CORS_ORIGINS=http://localhost:3050
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# Internal Service URLs
AUTH_SERVICE_URL=http://localhost:4151
INTEGRATION_SERVICE_URL=http://localhost:4152
MAIL_SERVICE_URL=http://localhost:4153
CALENDAR_SERVICE_URL=http://localhost:4154
COMMAND_SERVICE_URL=http://localhost:4155
AI_SERVICE_URL=http://localhost:4156
AGENT_SERVICE_URL=http://localhost:4157
SEARCH_SERVICE_URL=http://localhost:4158
WEBHOOK_SERVICE_URL=http://localhost:4159
WORKER_SERVICE_URL=http://localhost:4160
REALTIME_SERVICE_URL=http://localhost:4161

# Database
DATABASE_URL=postgres://actiondesk:actiondesk_dev_password@localhost:55450/actiondesk_ai
DATABASE_SSL=false
POSTGRES_USER=actiondesk
POSTGRES_PASSWORD=actiondesk_dev_password
POSTGRES_DB=actiondesk_ai
POSTGRES_PORT=55450

# Redis
REDIS_URL=redis://localhost:6390
REDIS_PREFIX=actiondesk
REDIS_PORT=6390

# Auth
AUTH_JWT_ACCESS_SECRET=replace-with-local-dev-secret-at-least-32-chars
AUTH_JWT_REFRESH_SECRET=replace-with-local-dev-secret-at-least-32-chars
AUTH_ACCESS_TOKEN_TTL_SECONDS=900
AUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_NAME=actiondesk_session

# Password Hashing
PASSWORD_HASH_MEMORY_COST=19456
PASSWORD_HASH_TIME_COST=2
PASSWORD_HASH_PARALLELISM=1

# Corsair
CORSAIR_API_KEY=
CORSAIR_APP_ID=
CORSAIR_WEBHOOK_SECRET=
CORSAIR_REDIRECT_BASE_URL=http://localhost:3050/auth/callback

# AI placeholder
AI_PROVIDER=
AI_API_KEY=
AI_MODEL=

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
SERVICE_NAMESPACE=actiondesk-ai

# Security
TRUST_PROXY=false
SECURE_COOKIES=false
ENCRYPTION_KEY=
