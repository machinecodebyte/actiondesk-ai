{
  "name": "actiondesk-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write .",
    "clean": "turbo run clean && rimraf node_modules .turbo",
    "db:generate": "pnpm --filter @actiondesk/db db:generate",
    "db:migrate": "pnpm --filter @actiondesk/db db:migrate",
    "dev:web": "pnpm --filter @actiondesk/web dev",
    "dev:web:alt": "pnpm --filter @actiondesk/web dev:alt",
    "dev:gateway": "pnpm --filter @actiondesk/api-gateway dev",
    "dev:auth": "pnpm --filter @actiondesk/auth-service dev",
    "dev:integration": "pnpm --filter @actiondesk/integration-service dev",
    "dev:mail": "pnpm --filter @actiondesk/mail-service dev",
    "dev:calendar": "pnpm --filter @actiondesk/calendar-service dev",
    "dev:command": "pnpm --filter @actiondesk/command-service dev",
    "dev:core": "node scripts/dev-core.mjs",
    "dev:all": "turbo run dev --parallel",
    "test": "tsx --test \"packages/*/test/**/*.test.ts\" \"apps/*/test/**/*.test.ts\""
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.0",
    "drizzle-orm": "^0.39.3",
    "eslint": "^9.20.0",
    "postgres": "^3.4.5",
    "prettier": "^3.5.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.0"
  }
}
